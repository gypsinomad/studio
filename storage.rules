
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() { return request.auth != null; }
    
    // Simplified for team collaboration: any signed-in team member can access export documents
    match /documents/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Default catch-all for other storage needs
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
