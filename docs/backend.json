{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the CRM system.",
      "properties": {
        "authUid": {
          "type": "string",
          "description": "The unique identifier from Firebase Authentication."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name."
        },
        "role": {
          "type": "string",
          "description": "User's role (e.g., admin, salesExecutive, viewer).",
          "enum": ["admin", "salesExecutive", "viewer"]
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the user account is active."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the user account was created.",
          "format": "date-time"
        }
      },
      "required": [
        "authUid",
        "email",
        "displayName",
        "role",
        "isActive",
        "createdAt"
      ]
    },
    "Lead": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lead",
      "type": "object",
      "description": "Represents a potential customer or deal.",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Lead's full name."
        },
        "companyName": {
          "type": "string",
          "description": "Lead's company name."
        },
        "email": {
          "type": "string",
          "description": "Lead's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Lead's phone number."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "Lead's WhatsApp number."
        },
        "source": {
          "type": "string",
          "description": "Source of the lead.",
          "enum": [
            "manual",
            "website",
            "whatsapp",
            "metaWhatsapp",
            "facebookLeadAds",
            "instagramDm",
            "tradeShow",
            "referral",
            "b2bPortal"
          ]
        },
        "productInterest": {
          "type": "string",
          "description": "Product the lead is interested in (e.g. spices, honey)."
        },
        "destinationCountry": {
          "type": "string",
          "description": "Destination country for the lead."
        },
        "incotermsPreference": {
          "type": "string",
          "description": "Incoterms preference for the lead."
        },
        "status": {
          "type": "string",
          "description": "Status of the lead.",
          "enum": [
            "new",
            "contacted",
            "qualified",
            "quoted",
            "converted",
            "lost"
          ]
        },
        "assignedUserId": {
          "type": "string",
          "description": "Reference to the User assigned to this lead."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the lead was created.",
          "format": "date-time"
        },
        "lastContactAt": {
          "type": "string",
          "description": "Timestamp of the last contact with the lead.",
          "format": "date-time"
        },
        "nextFollowUpAt": {
          "type": "string",
          "description": "Timestamp of the next follow-up with the lead.",
          "format": "date-time"
        },
        "metaLeadId": {
          "type": "string",
          "description": "Optional ID from Meta for the lead."
        },
        "whatsappThreadId": {
          "type": "string",
          "description": "Optional ID for the WhatsApp thread."
        },
        "metaFormId": {
          "type": "string",
          "description": "Optional ID for the Meta form used."
        },
        "metaPageId": {
          "type": "string",
          "description": "Optional ID for the Meta page."
        },
        "lastInboundChannel": {
          "type": "string",
          "description": "The last channel a message was received from.",
          "enum": ["whatsapp", "facebook", "instagram", "other"]
        }
      },
      "required": [
        "fullName",
        "companyName",
        "email",
        "phone",
        "source",
        "productInterest",
        "destinationCountry",
        "status",
        "assignedUserId",
        "createdAt"
      ]
    },
    "ExportOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExportOrder",
      "type": "object",
      "description": "Represents an export order.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the export order."
        },
        "stage": {
          "type": "string",
          "description": "Stage of the export order.",
          "enum": ["leadReceived", "quotationSent", "orderConfirmed", "exportDocumentation", "shipmentReady", "shippedDelivered", "cancelled", "lostNoResponse"]
        },
        "contactId": {
          "type": "string",
          "description": "Reference to the primary Contact for this order."
        },
        "companyId": {
          "type": "string",
          "description": "Reference to the Customer Company for this order."
        },
        "destinationCountry": {
          "type": "string",
          "description": "Destination country for the export order."
        },
        "destinationPort": {
          "type": "string",
          "description": "Destination port for the export order."
        },
        "incoterms": {
          "type": "string",
          "description": "Incoterms for the export order."
        },
        "totalValue": {
          "type": "number",
          "description": "Total value of the export order in USD."
        },
        "paymentTerms": {
          "type": "string",
          "description": "Payment terms for the export order."
        },
        "assignedUserId": {
          "type": "string",
          "description": "Reference to the User assigned to this order."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the export order was created.",
          "format": "date-time"
        },
        "aiValidation": {
          "type": "string",
          "description": "AI validation suggestions for the export order."
        },
        "expectedShipmentDate": {
            "type": "string",
            "format": "date-time",
            "description": "The expected date of shipment."
        },
        "portOfLoading": {
            "type": "string",
            "description": "The port where the goods will be loaded."
        },
        "containerType": {
            "type": "string",
            "description": "The type of container used (e.g., '20ft', '40ft HC')."
        },
        "fssaiLicenseNumber": {
            "type": "string",
            "description": "FSSAI license number of the exporter."
        },
        "icegateStatus": {
            "type": "string",
            "description": "Status from the ICEGATE portal.",
            "enum": ["Not Started", "Documentation Submitted", "Under Review", "Approved", "Rejected", "Clearance Completed"]
        },
        "certificateRequirements": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of required certificates for the export."
        },
        "productType": {
          "type": "string",
          "description": "The primary type of product in the order (e.g. Cardamom, Black Pepper)."
        },
        "hsCode": {
          "type": "string",
          "description": "Harmonized System code for the overall shipment."
        }
      },
      "required": [
        "title",
        "stage",
        "contactId",
        "companyId",
        "destinationCountry",
        "incoterms",
        "totalValue",
        "paymentTerms",
        "assignedUserId",
        "createdAt"
      ]
    },
    "LineItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LineItem",
      "type": "object",
      "description": "Represents a single line item within an ExportOrder.",
      "properties": {
        "productName": {
          "type": "string",
          "description": "Name of the product for this line item."
        },
        "productType": {
          "type": "string",
          "description": "Category or type of the product."
        },
        "hsCode": {
            "type": "string",
            "description": "Harmonized System code for the product."
        },
        "unitPrice": {
            "type": "number",
            "description": "Price per unit (e.g., per kg)."
        },
        "quantity": {
          "type": "number",
          "description": "Total quantity of the product in kg."
        },
        "boxes": {
          "type": "number",
          "description": "Number of boxes for this product."
        },
        "packing": {
          "type": "string",
          "description": "Packing description (e.g. '25kg PP bags')."
        },
        "grossWeightPerBox": {
          "type": "number",
          "description": "Gross weight per box in kg."
        },
        "netWeightPerBox": {
          "type": "number",
          "description": "Net weight of the produce per box in kg."
        }
      },
      "required": ["productName", "quantity", "boxes", "grossWeightPerBox", "netWeightPerBox", "unitPrice", "hsCode"]
    },
    "Contact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contact",
      "type": "object",
      "description": "Represents a contact person, e.g. at a buyer company.",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "First name of the contact."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the contact."
        },
        "email": {
          "type": "string",
          "description": "Email address of the contact.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the contact."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "WhatsApp number of the contact."
        },
        "jobTitle": {
          "type": "string",
          "description": "Job title of the contact (e.g. Purchase Manager)."
        },
        "contactRole": {
          "type": "string",
          "description": "The role of the contact in the buying process (e.g., Decision Maker)."
        },
        "preferredCommunicationMethod": {
            "type": "string",
            "description": "The preferred method of communication.",
            "enum": ["email", "phone", "whatsapp"]
        },
        "companyId": {
            "type": "string",
            "description": "Reference to the Company this contact belongs to."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the contact was created.",
          "format": "date-time"
        },
        "decisionMaker": {
          "type": "boolean",
          "description": "Indicates if the contact is a decision maker."
        },
        "contactSource": {
          "type": "string",
          "description": "Where this contact originated from."
        }
      },
      "required": [
        "firstName",
        "lastName",
        "email",
        "phone",
        "createdAt"
      ]
    },
    "Company": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Company",
        "type": "object",
        "description": "Represents a customer company.",
        "properties": {
            "name": { "type": "string", "description": "Name of the customer company." },
            "country": { "type": "string", "description": "Country where the company is located." },
            "website": { "type": "string", "description": "Company's official website." },
            "industryType": { "type": "string", "description": "The industry the company operates in.", "enum": ["Wholesaler", "Retailer", "Food Processor", "Restaurant Chain"] },
            "paymentTerms": { "type": "string", "description": "Standard payment terms with this company.", "enum": ["Advance", "L/C", "D/P", "D/A", "CAD"] },
            "relationshipStatus": { "type": "string", "description": "The status of the business relationship.", "enum": ["New", "Active", "VIP", "Inactive"] },
            "createdAt": { "type": "string", "format": "date-time" },
            "taxId": { "type": "string", "description": "Company's Tax ID or VAT number." },
            "importLicense": { "type": "string", "description": "Company's Import License number." },
            "preferredIncoterms": {
                "type": "string",
                "description": "The company's preferred incoterms."
            }
        },
        "required": ["name", "country", "createdAt"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task in the CRM system.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the task."
        },
        "description": {
          "type": "string",
          "description": "Description of the task."
        },
        "status": {
          "type": "string",
          "description": "Status of the task.",
          "enum": ["open", "inProgress", "done"]
        },
        "dueDate": {
          "type": "string",
          "description": "Due date of the task.",
          "format": "date-time"
        },
        "relatedLeadId": {
          "type": "string",
          "description": "Reference to a Lead."
        },
        "relatedOrderId": {
          "type": "string",
          "description": "Reference to an ExportOrder."
        },
        "assigneeId": {
          "type": "string",
          "description": "Reference to the User assigned to this task."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the task was created.",
          "format": "date-time"
        }
      },
      "required": [
        "title",
        "status",
        "dueDate",
        "assigneeId",
        "createdAt"
      ]
    },
    "Document": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Document",
      "type": "object",
      "description": "Represents a document in the CRM system.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the document."
        },
        "type": {
          "type": "string",
          "description": "Type of document.",
          "enum": ["proformaInvoice", "contract", "packingList", "billOfLading", "coo", "fssai", "apeda", "phytoCertificate", "shippingBill", "other"]
        },
        "relatedLeadId": {
          "type": "string",
          "description": "Reference to a Lead."
        },
        "relatedOrderId": {
          "type": "string",
          "description": "Reference to an ExportOrder."
        },
        "fileUrl": {
          "type": "string",
          "description": "URL of the document file in Cloud Storage.",
          "format": "uri"
        },
        "status": {
          "type": "string",
          "description": "Status of the document.",
          "enum": ["pending", "uploaded", "verified"]
        },
        "expiryDate": {
          "type": "string",
          "description": "Expiry date of the document.",
          "format": "date-time"
        },
        "uploadedBy": {
          "type": "string",
          "description": "User who uploaded the document."
        },
        "uploadedAt": {
          "type": "string",
          "description": "Timestamp of when the document was uploaded.",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "type",
        "fileUrl",
        "status",
        "uploadedBy",
        "uploadedAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product offered by the company.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the product."
        },
        "description": {
          "type": "string",
          "description": "Description of the product."
        },
        "hsCode": {
          "type": "string",
          "description": "Harmonized System code for the product."
        },
        "basePrice": {
          "type": "number",
          "description": "Base price per unit."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL for the product image.",
          "format": "uri"
        }
      },
      "required": [
        "name",
        "hsCode",
        "basePrice"
      ]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "Represents a note related to another entity.",
      "properties": {
        "content": {
          "type": "string",
          "description": "The content of the note."
        },
        "relatedEntityType": {
          "type": "string",
          "description": "The type of entity this note is related to (e.g., 'Lead', 'Contact')."
        },
        "relatedEntityId": {
          "type": "string",
          "description": "The ID of the entity this note is related to."
        },
        "createdBy": {
          "type": "string",
          "description": "User ID of the note's creator."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the note was created.",
          "format": "date-time"
        }
      },
      "required": [
        "content",
        "relatedEntityType",
        "relatedEntityId",
        "createdBy",
        "createdAt"
      ]
    },
    "ActivityLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActivityLog",
      "type": "object",
      "description": "A log of an activity that occurred.",
      "properties": {
        "icon": {
          "type": "string",
          "description": "Lucide icon name for the activity."
        },
        "title": {
          "type": "string",
          "description": "A short title for the activity."
        },
        "description": {
          "type": "string",
          "description": "A longer description of the activity."
        },
        "timestamp": {
          "type": "string",
          "description": "When the activity occurred.",
          "format": "date-time"
        }
      },
      "required": [
        "icon",
        "title",
        "description",
        "timestamp"
      ]
    },
    "AuditLog": {
      "title": "AuditLog",
      "type": "object",
      "description": "An audit trail entry for a CUD operation.",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "collectionName": { "type": "string" },
        "docId": { "type": "string" },
        "action": { "type": "string", "enum": ["create", "update", "delete"] },
        "before": { "type": "object" },
        "after": { "type": "object" }
      },
      "required": ["timestamp", "userId", "userEmail", "collectionName", "docId", "action"]
    },
    "DashboardStats": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DashboardStats",
      "type": "object",
      "description": "Pre-aggregated statistics for a user's dashboard for fast reads.",
      "properties": {
        "totalLeads": { "type": "number" },
        "activeExportOrders": { "type": "number" },
        "leadsByStatus": {
            "type": "object",
            "properties": {
                "new": { "type": "number" },
                "contacted": { "type": "number" },
                "qualified": { "type": "number" },
                "quoted": { "type": "number" },
                "converted": { "type": "number" },
                "lost": { "type": "number" }
            }
        },
        "exportOrdersByStage": {
            "type": "object",
            "properties": {
                "leadReceived": { "type": "number" },
                "quotationSent": { "type": "number" },
                "orderConfirmed": { "type": "number" },
                "exportDocumentation": { "type": "number" },
                "shipmentReady": { "type": "number" },
                "shippedDelivered": { "type": "number" },
                "cancelled": { "type": "number" },
                "lostNoResponse": { "type": "number" }
            }
        },
        "lastUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["totalLeads", "activeExportOrders", "leadsByStatus", "exportOrdersByStage", "lastUpdatedAt"]
    },
    "WhatsappEvent": {
      "title": "WhatsappEvent",
      "type": "object",
      "description": "A log of a raw webhook payload from the WhatsApp Cloud API for debugging.",
      "properties": {
        "rawPayload": {
          "type": "object",
          "description": "The full, unprocessed JSON payload from Meta."
        },
        "processedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the event was processed."
        },
        "eventType": {
          "type": "string",
          "description": "The type of event (e.g., 'message', 'status')."
        },
        "leadId": {
          "type": "string",
          "description": "The ID of the lead that was created or affected."
        },
        "contactId": {
          "type": "string",
          "description": "The ID of the contact that was created or affected."
        },
        "error": {
          "type": "string",
          "description": "Records any error that occurred during processing."
        }
      },
      "required": ["rawPayload", "processedAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/entities/User" },
          "description": "Stores user profiles for the internal team. The document ID (`userId`) MUST MATCH the Firebase Authentication UID (`authUid`)."
        }
      },
      {
        "path": "/dashboardStats/{userId}",
        "definition": {
          "schema": { "$ref": "#/entities/DashboardStats" },
          "description": "Stores pre-aggregated dashboard data for each user. The document ID is the user's UID."
        }
      },
       {
        "path": "/whatsappEvents/{eventId}",
        "definition": {
          "schema": { "$ref": "#/entities/WhatsappEvent" },
          "description": "Stores raw webhook events from WhatsApp Cloud API for debugging purposes."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "schema": { "$ref": "#/entities/Company" },
          "description": "Stores customer companies."
        }
      },
      {
        "path": "/contacts/{contactId}",
        "definition": {
          "schema": { "$ref": "#/entities/Contact" },
          "description": "Stores contacts associated with buyers and partners."
        }
      },
      {
        "path": "/leads/{leadId}",
        "definition": {
          "schema": { "$ref": "#/entities/Lead" },
          "description": "Stores all leads for the company."
        }
      },
      {
        "path": "/exportOrders/{exportOrderId}",
        "definition": {
          "schema": { "$ref": "#/entities/ExportOrder" },
          "description": "Stores all export orders for the company."
        }
      },
      {
        "path": "/exportOrders/{exportOrderId}/lineItems/{lineItemId}",
        "definition": {
          "schema": { "$ref": "#/entities/LineItem" },
          "description": "Stores the individual line items for an export order."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "schema": { "$ref": "#/entities/Product" },
          "description": "Stores products offered by the company."
        }
      },
      {
        "path": "/notes/{noteId}",
        "definition": {
          "schema": { "$ref": "#/entities/Note" },
          "description": "Stores notes associated with various entities."
        }
      },
      {
        "path": "/documents/{documentId}",
        "definition": {
          "schema": { "$ref": "#/entities/Document" },
          "description": "Stores all documents for the company."
        }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": {
          "schema": { "$ref": "#/entities/Task" },
          "description": "Stores all tasks for the team."
        }
      },
      {
        "path": "/activityLogs/{logId}",
        "definition": {
          "schema": { "$ref": "#/entities/AuditLog" },
          "description": "Stores an audit trail of all create, update, and delete operations."
        }
      },
       {
        "path": "/activity_logs/{logId}",
        "definition": {
          "schema": { "$ref": "#/entities/ActivityLog" },
          "description": "Stores a timeline of activities for the company."
        }
      }
    ],
    "reasoning": "The Firestore structure is now flat and optimized for a single company's internal use. All primary business data collections are at the root level. This simplifies queries and application logic, removing the need for multi-tenant checks. User profiles are kept in a top-level collection for authentication and role management purposes."
  }
}
