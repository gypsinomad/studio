{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the CRM system.",
      "properties": {
        "authUid": {
          "type": "string",
          "description": "The unique identifier from Firebase Authentication."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name."
        },
        "role": {
          "type": "string",
          "description": "User's role (e.g., admin, salesExecutive).",
          "enum": ["admin", "salesExecutive"]
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the user account is active."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the user account was created.",
          "format": "date-time"
        },
        "companyIds": {
          "type": "array",
          "description": "References to Companies the user belongs to. (Relationship: User N:N Company)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "authUid",
        "email",
        "displayName",
        "role",
        "isActive",
        "createdAt",
        "companyIds"
      ]
    },
    "Lead": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lead",
      "type": "object",
      "description": "Represents a potential customer or deal, belonging to a specific company.",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Lead's full name."
        },
        "companyName": {
          "type": "string",
          "description": "Lead's company name."
        },
        "email": {
          "type": "string",
          "description": "Lead's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Lead's phone number."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "Lead's WhatsApp number."
        },
        "source": {
          "type": "string",
          "description": "Source of the lead.",
          "enum": [
            "manual",
            "website",
            "whatsapp",
            "metaWhatsapp",
            "facebookLeadAds",
            "instagramDm",
            "tradeShow",
            "referral"
          ]
        },
        "productInterest": {
          "type": "string",
          "description": "Product the lead is interested in."
        },
        "destinationCountry": {
          "type": "string",
          "description": "Destination country for the lead."
        },
        "incotermsPreference": {
          "type": "string",
          "description": "Incoterms preference for the lead."
        },
        "status": {
          "type": "string",
          "description": "Status of the lead.",
          "enum": [
            "new",
            "contacted",
            "qualified",
            "quoted",
            "converted",
            "lost"
          ]
        },
        "assignedUserId": {
          "type": "string",
          "description": "Reference to the User assigned to this lead."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the lead was created.",
          "format": "date-time"
        },
        "lastContactAt": {
          "type": "string",
          "description": "Timestamp of the last contact with the lead.",
          "format": "date-time"
        },
        "nextFollowUpAt": {
          "type": "string",
          "description": "Timestamp of the next follow-up with the lead.",
          "format": "date-time"
        },
        "metaLeadId": {
          "type": "string",
          "description": "Optional ID from Meta for the lead."
        },
        "whatsappThreadId": {
          "type": "string",
          "description": "Optional ID for the WhatsApp thread."
        },
        "metaFormId": {
          "type": "string",
          "description": "Optional ID for the Meta form used."
        },
        "metaPageId": {
          "type": "string",
          "description": "Optional ID for the Meta page."
        },
        "lastInboundChannel": {
          "type": "string",
          "description": "The last channel a message was received from.",
          "enum": ["whatsapp", "facebook", "instagram", "other"]
        }
      },
      "required": [
        "fullName",
        "companyName",
        "email",
        "phone",
        "source",
        "productInterest",
        "destinationCountry",
        "status",
        "assignedUserId",
        "createdAt"
      ]
    },
    "ExportOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExportOrder",
      "type": "object",
      "description": "Represents an export order, belonging to a specific company.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the export order."
        },
        "stage": {
          "type": "string",
          "description": "Stage of the export order.",
           "enum": ["leadReceived", "quotationSent", "orderConfirmed", "exportDocumentation", "shipmentReady", "shippedDelivered", "cancelled", "lostNoResponse"]
        },
        "contactId": {
          "type": "string",
          "description": "Reference to the primary Contact for this order."
        },
        "destinationCountry": {
          "type": "string",
          "description": "Destination country for the export order."
        },
        "incoterms": {
          "type": "string",
          "description": "Incoterms for the export order."
        },
        "totalValue": {
          "type": "number",
          "description": "Total value of the export order in USD."
        },
        "paymentTerms": {
          "type": "string",
          "description": "Payment terms for the export order."
        },
        "assignedUserId": {
          "type": "string",
          "description": "Reference to the User assigned to this order."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the export order was created.",
          "format": "date-time"
        },
        "aiValidation": {
          "type": "string",
          "description": "AI validation suggestions for the export order."
        }
      },
      "required": [
        "title",
        "stage",
        "contactId",
        "destinationCountry",
        "incoterms",
        "totalValue",
        "paymentTerms",
        "assignedUserId",
        "createdAt"
      ]
    },
    "LineItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LineItem",
      "type": "object",
      "description": "Represents a single line item within an ExportOrder.",
      "properties": {
        "productName": {
          "type": "string",
          "description": "Name of the product for this line item."
        },
        "quantity": {
          "type": "number",
          "description": "Total quantity of the product in kg."
        },
        "boxes": {
          "type": "number",
          "description": "Number of boxes for this product."
        },
        "grossWeightPerBox": {
          "type": "number",
          "description": "Gross weight per box in kg."
        },
        "netWeightPerBox": {
          "type": "number",
          "description": "Net weight of the produce per box in kg."
        }
      },
      "required": ["productName", "quantity", "boxes", "grossWeightPerBox", "netWeightPerBox"]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a company tenant in the CRM system. This is the root for most other data.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the company."
        },
        "address": {
          "type": "string",
          "description": "Address of the company."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the company."
        },
        "email": {
          "type": "string",
          "description": "Email address of the company.",
          "format": "email"
        },
        "website": {
          "type": "string",
          "description": "Website of the company.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the company was created.",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "createdAt"
      ]
    },
    "Contact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contact",
      "type": "object",
      "description": "Represents a contact person, belonging to a specific company.",
      "properties": {
        "firstName": {
          "type": "string",
          "description": "First name of the contact."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the contact."
        },
        "email": {
          "type": "string",
          "description": "Email address of the contact.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the contact."
        },
        "jobTitle": {
          "type": "string",
          "description": "Job title of the contact."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the contact was created.",
          "format": "date-time"
        }
      },
      "required": [
        "firstName",
        "lastName",
        "email",
        "phone",
        "createdAt"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task in the CRM system.",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the task."
        },
        "description": {
          "type": "string",
          "description": "Description of the task."
        },
        "status": {
          "type": "string",
          "description": "Status of the task.",
          "enum": ["open", "inProgress", "done"]
        },
        "dueDate": {
          "type": "string",
          "description": "Due date of the task.",
          "format": "date-time"
        },
        "relatedLeadId": {
          "type": "string",
          "description": "Reference to a Lead within the same company."
        },
        "relatedOrderId": {
          "type": "string",
          "description": "Reference to an ExportOrder within the same company."
        },
        "assigneeId": {
          "type": "string",
          "description": "Reference to the User assigned to this task."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the task was created.",
          "format": "date-time"
        }
      },
      "required": [
        "title",
        "status",
        "dueDate",
        "assigneeId",
        "createdAt"
      ]
    },
    "Document": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Document",
      "type": "object",
      "description": "Represents a document in the CRM system.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the document."
        },
        "type": {
          "type": "string",
          "description": "Type of document.",
          "enum": ["invoice", "packingList", "billOfLading", "COO", "certificate", "other"]
        },
        "relatedLeadId": {
          "type": "string",
          "description": "Reference to a Lead within the same company."
        },
        "relatedOrderId": {
          "type": "string",
          "description": "Reference to an ExportOrder within the same company."
        },
        "fileUrl": {
          "type": "string",
          "description": "URL of the document file in Cloud Storage.",
          "format": "uri"
        },
        "status": {
          "type": "string",
          "description": "Status of the document.",
          "enum": ["pending", "uploaded", "verified"]
        },
        "expiryDate": {
          "type": "string",
          "description": "Expiry date of the document.",
          "format": "date-time"
        },
        "uploadedBy": {
          "type": "string",
          "description": "User who uploaded the document."
        },
        "uploadedAt": {
          "type": "string",
          "description": "Timestamp of when the document was uploaded.",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "type",
        "fileUrl",
        "status",
        "uploadedBy",
        "uploadedAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product offered by a company.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the product."
        },
        "description": {
          "type": "string",
          "description": "Description of the product."
        },
        "hsCode": {
          "type": "string",
          "description": "Harmonized System code for the product."
        },
        "basePrice": {
          "type": "number",
          "description": "Base price per unit."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL for the product image.",
          "format": "uri"
        }
      },
      "required": [
        "name",
        "hsCode",
        "basePrice"
      ]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "Represents a note related to another entity within a company.",
      "properties": {
        "content": {
          "type": "string",
          "description": "The content of the note."
        },
        "relatedEntityType": {
          "type": "string",
          "description": "The type of entity this note is related to (e.g., 'Lead', 'Contact')."
        },
        "relatedEntityId": {
          "type": "string",
          "description": "The ID of the entity this note is related to."
        },
        "createdBy": {
          "type": "string",
          "description": "User ID of the note's creator."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the note was created.",
          "format": "date-time"
        }
      },
      "required": [
        "content",
        "relatedEntityType",
        "relatedEntityId",
        "createdBy",
        "createdAt"
      ]
    },
    "ActivityLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ActivityLog",
      "type": "object",
      "description": "A log of an activity that occurred within a company.",
      "properties": {
        "icon": {
          "type": "string",
          "description": "Lucide icon name for the activity."
        },
        "title": {
          "type": "string",
          "description": "A short title for the activity."
        },
        "description": {
          "type": "string",
          "description": "A longer description of the activity."
        },
        "timestamp": {
          "type": "string",
          "description": "When the activity occurred.",
          "format": "date-time"
        }
      },
      "required": [
        "icon",
        "title",
        "description",
        "timestamp"
      ]
    },
    "DashboardStats": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DashboardStats",
      "type": "object",
      "description": "Pre-aggregated statistics for a user's dashboard for fast reads.",
      "properties": {
        "totalLeads": { "type": "number" },
        "activeExportOrders": { "type": "number" },
        "leadsByStatus": {
            "type": "object",
            "properties": {
                "new": { "type": "number" },
                "contacted": { "type": "number" },
                "qualified": { "type": "number" },
                "quoted": { "type": "number" },
                "converted": { "type": "number" },
                "lost": { "type": "number" }
            }
        },
        "exportOrdersByStage": {
            "type": "object",
            "properties": {
                "leadReceived": { "type": "number" },
                "quotationSent": { "type": "number" },
                "orderConfirmed": { "type": "number" },
                "exportDocumentation": { "type": "number" },
                "shipmentReady": { "type": "number" },
                "shippedDelivered": { "type": "number" },
                "cancelled": { "type": "number" },
                "lostNoResponse": { "type": "number" }
            }
        },
        "lastUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["totalLeads", "activeExportOrders", "leadsByStatus", "exportOrdersByStage", "lastUpdatedAt"]
    },
    "WhatsappEvent": {
      "title": "WhatsappEvent",
      "type": "object",
      "description": "A log of a raw webhook payload from the WhatsApp Cloud API for debugging.",
      "properties": {
        "rawPayload": {
          "type": "object",
          "description": "The full, unprocessed JSON payload from Meta."
        },
        "processedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the event was processed."
        },
        "eventType": {
          "type": "string",
          "description": "The type of event (e.g., 'message', 'status')."
        },
        "leadId": {
          "type": "string",
          "description": "The ID of the lead that was created or affected."
        },
        "contactId": {
          "type": "string",
          "description": "The ID of the contact that was created or affected."
        },
        "error": {
          "type": "string",
          "description": "Records any error that occurred during processing."
        }
      },
      "required": ["rawPayload", "processedAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": { "$ref": "#/entities/User" },
          "description": "Stores user profiles. The document ID (`userId`) MUST MATCH the Firebase Authentication UID (`authUid`)."
        }
      },
      {
        "path": "/dashboardStats/{userId}",
        "definition": {
          "schema": { "$ref": "#/entities/DashboardStats" },
          "description": "Stores pre-aggregated dashboard data for each user. The document ID is the user's UID."
        }
      },
       {
        "path": "/whatsappEvents/{eventId}",
        "definition": {
          "schema": { "$ref": "#/entities/WhatsappEvent" },
          "description": "Stores raw webhook events from WhatsApp Cloud API for debugging purposes. Not tied to a company."
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "schema": { "$ref": "#/entities/Company" },
          "description": "Root collection for all company data, enabling multi-tenancy."
        }
      },
      {
        "path": "/companies/{companyId}/contacts/{contactId}",
        "definition": {
          "schema": { "$ref": "#/entities/Contact" },
          "description": "Stores contacts associated with a company."
        }
      },
      {
        "path": "/companies/{companyId}/leads/{leadId}",
        "definition": {
          "schema": { "$ref": "#/entities/Lead" },
          "description": "Stores leads associated with a company."
        }
      },
      {
        "path": "/companies/{companyId}/exportOrders/{exportOrderId}",
        "definition": {
          "schema": { "$ref": "#/entities/ExportOrder" },
          "description": "Stores export orders associated with a company."
        }
      },
      {
        "path": "/companies/{companyId}/exportOrders/{exportOrderId}/lineItems/{lineItemId}",
        "definition": {
          "schema": { "$ref": "#/entities/LineItem" },
          "description": "Stores the individual line items for an export order."
        }
      },
      {
        "path": "/companies/{companyId}/products/{productId}",
        "definition": {
          "schema": { "$ref": "#/entities/Product" },
          "description": "Stores products offered by a specific company."
        }
      },
      {
        "path": "/companies/{companyId}/notes/{noteId}",
        "definition": {
          "schema": { "$ref": "#/entities/Note" },
          "description": "Stores notes associated with various entities within a company."
        }
      },
      {
        "path": "/companies/{companyId}/documents/{documentId}",
        "definition": {
          "schema": { "$ref": "#/entities/Document" },
          "description": "Stores documents associated with a company."
        }
      },
      {
        "path": "/companies/{companyId}/tasks/{taskId}",
        "definition": {
          "schema": { "$ref": "#/entities/Task" },
          "description": "Stores tasks associated with a company."
        }
      },
       {
        "path": "/companies/{companyId}/activity_logs/{logId}",
        "definition": {
          "schema": { "$ref": "#/entities/ActivityLog" },
          "description": "Stores a timeline of activities for a company."
        }
      }
    ],
    "reasoning": "The Firestore structure is designed for multi-tenancy. All primary business data is nested within a `/companies/{companyId}` collection. A user's access to a company's data is determined by checking if the `companyId` is in the `companyIds` array on their user profile (`/users/{userId}`). This is a scalable and secure pattern for SaaS applications. User profiles are kept in a top-level collection for authentication purposes."
  }
}
