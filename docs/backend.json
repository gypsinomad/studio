{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user within the SpiceRoute CRM application.",
      "properties": {
        "authUid": {
          "type": "string",
          "description": "The Firebase Authentication UID associated with the user."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "description": "The user's role within the system (e.g., admin, salesExecutive)."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates whether the user account is active."
        },
        "createdAt": {
          "type": "string",
          "description": "The timestamp when the user account was created.",
          "format": "date-time"
        }
      },
      "required": ["authUid", "email", "displayName", "role", "isActive", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "description": "Represents a lead in the CRM system.",
      "properties": {
        "fullName": { "type": "string" },
        "companyName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "source": { "type": "string" },
        "productInterest": { "type": "string" },
        "destinationCountry": { "type": "string" },
        "incotermsPreference": { "type": "string" },
        "status": { "type": "string" },
        "assignedUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastContactAt": { "type": "string", "format": "date-time" },
        "nextFollowUpAt": { "type": "string", "format": "date-time" },
        "tagIds": { "type": "array", "items": { "type": "string" } },
        "exportOrderId": { "type": "string" }
      },
      "required": ["fullName", "companyName", "email", "phone", "source", "productInterest", "destinationCountry", "status", "assignedUserId", "createdAt"]
    },
    "ExportOrder": {
      "title": "ExportOrder",
      "type": "object",
      "description": "Represents an export order in the CRM system.",
      "properties": {
        "title": { "type": "string" },
        "stage": { "type": "string" },
        "companyId": { "type": "string" },
        "contactId": { "type": "string" },
        "productType": { "type": "string" },
        "destinationCountry": { "type": "string" },
        "incoterms": { "type": "string" },
        "hsCode": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "paymentTerms": { "type": "string" },
        "containerType": { "type": "string" },
        "portOfLoading": { "type": "string" },
        "expectedShipmentDate": { "type": "string", "format": "date-time" },
        "fssaiLicenseNumber": { "type": "string" },
        "icegateStatus": { "type": "string" },
        "certificateRequirements": { "type": "array", "items": { "type": "string" } },
        "assignedUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "aiValidation": { "type": "string" }
      },
      "required": ["title", "stage", "companyId", "contactId", "productType", "destinationCountry", "incoterms", "hsCode", "quantity", "unitPrice", "paymentTerms", "containerType", "portOfLoading", "expectedShipmentDate", "assignedUserId", "createdAt"]
    },
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "Represents a company in the CRM system.",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "website": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "type": "object",
      "description": "Represents a contact person in the CRM system.",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "companyId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "phone", "companyId", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "type": "object",
      "description": "Represents a task in the CRM system.",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "relatedLeadId": { "type": "string" },
        "relatedOrderId": { "type": "string" },
        "assigneeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "status", "dueDate", "assigneeId", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "type": "object",
      "description": "Represents a document in the CRM system.",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "orderId": { "type": "string" },
        "leadId": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "fileUrl", "status", "uploadedBy", "uploadedAt"]
    },
    "Tag": {
      "title": "Tag",
      "type": "object",
      "description": "Represents a tag that can be associated with leads.",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "DashboardStats": {
      "title": "DashboardStats",
      "type": "object",
      "description": "Pre-aggregated statistics for a user's dashboard to improve performance.",
      "properties": {
        "totalLeads": { "type": "number" },
        "activeExportOrders": { "type": "number" },
        "leadsByStatus": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "exportOrdersByStage": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "lastUpdatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["totalLeads", "activeExportOrders", "leadsByStatus", "exportOrdersByStage", "lastUpdatedAt"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles. The 'userId' parameter corresponds to the Firebase Auth UID. The 'role' field is used for RBAC."
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Stores lead data. Access is secured by the 'assignedUserId' field."
    },
    "/exportOrders/{exportOrderId}": {
      "schema": { "$ref": "#/entities/ExportOrder" },
      "description": "Stores export order data. Access is secured by the 'assignedUserId' field."
    },
    "/companies/{companyId}": {
      "schema": { "$ref": "#/entities/Company" },
      "description": "Stores company data. Readable by all authenticated users, writable only by admins."
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Stores contact data. Readable by all authenticated users, writable only by admins."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores task data. Access is secured by the 'assigneeId' field."
    },
    "/documents/{documentId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Stores document metadata. Access is secured by the 'uploadedBy' field."
    },
    "/tags/{tagId}": {
      "schema": { "$ref": "#/entities/Tag" },
      "description": "Stores tag data. Readable by all authenticated users, writable only by admins."
    },
     "/dashboardStats/{userId}": {
      "schema": { "$ref": "#/entities/DashboardStats" },
      "description": "Stores pre-aggregated dashboard statistics for each user to ensure fast dashboard loads. This document is written to by backend functions."
    }
  }
}
