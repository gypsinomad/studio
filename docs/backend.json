{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "authUid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "salesExecutive", "viewer"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Lead": {
      "title": "Lead",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "companyName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ExportOrder": {
      "title": "ExportOrder",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "stage": { "type": "string" },
        "totalValue": { "type": "number" },
        "destinationCountry": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Sales leads"
    },
    "/exportOrders/{orderId}": {
      "schema": { "$ref": "#/entities/ExportOrder" },
      "description": "Export orders"
    },
    "/activity_logs/{logId}": {
      "schema": { "type": "object" },
      "description": "Activity logs"
    },
    "/tasks/{taskId}": {
      "schema": { "type": "object" },
      "description": "Tasks"
    },
    "/settings/ai": {
      "schema": { "type": "object" },
      "description": "AI configuration"
    }
  }
}