{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the CRM system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "authUid": {
          "type": "string",
          "description": "The unique identifier from Firebase Authentication."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name."
        },
        "role": {
          "type": "string",
          "description": "User's role (e.g., admin, salesExecutive)."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the user account is active."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the user account was created.",
          "format": "date-time"
        },
        "companyIds": {
          "type": "array",
          "description": "References to Companies the user belongs to. (Relationship: User N:N Company)",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "authUid",
        "email",
        "displayName",
        "role",
        "isActive",
        "createdAt",
        "companyIds"
      ]
    },
    "Lead": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lead",
      "type": "object",
      "description": "Represents a lead in the CRM system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Lead entity."
        },
        "fullName": {
          "type": "string",
          "description": "Lead's full name."
        },
        "companyName": {
          "type": "string",
          "description": "Lead's company name."
        },
        "email": {
          "type": "string",
          "description": "Lead's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Lead's phone number."
        },
        "whatsappNumber": {
          "type": "string",
          "description": "Lead's WhatsApp number."
        },
        "source": {
          "type": "string",
          "description": "Source of the lead."
        },
        "productInterest": {
          "type": "string",
          "description": "Product the lead is interested in."
        },
        "destinationCountry": {
          "type": "string",
          "description": "Destination country for the lead."
        },
        "incotermsPreference": {
          "type": "string",
          "description": "Incoterms preference for the lead."
        },
        "status": {
          "type": "string",
          "description": "Status of the lead (new, contacted, qualified, quoted, converted, lost)."
        },
        "assignedUserId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N Lead)"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the lead was created.",
          "format": "date-time"
        },
        "lastContactAt": {
          "type": "string",
          "description": "Timestamp of the last contact with the lead.",
          "format": "date-time"
        },
        "nextFollowUpAt": {
          "type": "string",
          "description": "Timestamp of the next follow-up with the lead.",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "description": "Tags associated with the lead.",
          "items": {
            "type": "string"
          }
        },
        "exportOrderId": {
          "type": "string",
          "description": "Reference to ExportOrder. (Relationship: ExportOrder 1:N Lead)"
        },
        "companyId": {
          "type": "string",
          "description": "Reference to Company. (Relationship: Company 1:N Lead)"
        }
      },
      "required": [
        "id",
        "fullName",
        "companyName",
        "email",
        "phone",
        "source",
        "productInterest",
        "destinationCountry",
        "incotermsPreference",
        "status",
        "assignedUserId",
        "createdAt"
      ]
    },
    "ExportOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ExportOrder",
      "type": "object",
      "description": "Represents an export order in the CRM system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ExportOrder entity."
        },
        "title": {
          "type": "string",
          "description": "Title of the export order."
        },
        "stage": {
          "type": "string",
          "description": "Stage of the export order (leadReceived, quotationSent, orderConfirmed, exportDocumentation, shipmentReady, shippedDelivered, cancelled, lostNoResponse)."
        },
        "companyId": {
          "type": "string",
          "description": "Reference to Company. (Relationship: Company 1:N ExportOrder)"
        },
        "contactId": {
          "type": "string",
          "description": "Reference to Contact. (Relationship: Contact 1:N ExportOrder)"
        },
        "productType": {
          "type": "string",
          "description": "Type of product being exported."
        },
        "destinationCountry": {
          "type": "string",
          "description": "Destination country for the export order."
        },
        "incoterms": {
          "type": "string",
          "description": "Incoterms for the export order."
        },
        "hsCode": {
          "type": "string",
          "description": "HS code for the export order."
        },
        "quantity": {
          "type": "number",
          "description": "Quantity of the product being exported."
        },
        "unitPrice": {
          "type": "number",
          "description": "Unit price of the product being exported."
        },
        "paymentTerms": {
          "type": "string",
          "description": "Payment terms for the export order."
        },
        "containerType": {
          "type": "string",
          "description": "Container type for the export order."
        },
        "portOfLoading": {
          "type": "string",
          "description": "Port of loading for the export order."
        },
        "expectedShipmentDate": {
          "type": "string",
          "description": "Expected shipment date for the export order.",
          "format": "date-time"
        },
        "fssaiLicenseNumber": {
          "type": "string",
          "description": "FSSAI license number for the export order."
        },
        "icegateStatus": {
          "type": "string",
          "description": "Icegate status for the export order."
        },
        "certificateRequirements": {
          "type": "array",
          "description": "Certificate requirements for the export order.",
          "items": {
            "type": "string"
          }
        },
        "assignedUserId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N ExportOrder)"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the export order was created.",
          "format": "date-time"
        },
        "aiValidation": {
          "type": "string",
          "description": "AI validation suggestions for the export order."
        }
      },
      "required": [
        "id",
        "title",
        "stage",
        "companyId",
        "contactId",
        "productType",
        "destinationCountry",
        "incoterms",
        "hsCode",
        "quantity",
        "unitPrice",
        "paymentTerms",
        "containerType",
        "portOfLoading",
        "expectedShipmentDate",
        "assignedUserId",
        "createdAt"
      ]
    },
    "Company": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Company",
      "type": "object",
      "description": "Represents a company in the CRM system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Company entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the company."
        },
        "address": {
          "type": "string",
          "description": "Address of the company."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the company."
        },
        "email": {
          "type": "string",
          "description": "Email address of the company.",
          "format": "email"
        },
        "website": {
          "type": "string",
          "description": "Website of the company.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "name",
        "address",
        "phone",
        "email",
        "website"
      ]
    },
    "Contact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Contact",
      "type": "object",
      "description": "Represents a contact in the CRM system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Contact entity."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the contact."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the contact."
        },
        "email": {
          "type": "string",
          "description": "Email address of the contact.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the contact."
        },
        "companyId": {
          "type": "string",
          "description": "Reference to Company. (Relationship: Company 1:N Contact)"
        },
        "jobTitle": {
          "type": "string",
          "description": "Job title of the contact."
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email",
        "phone",
        "companyId"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a task in the CRM system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Task entity."
        },
        "title": {
          "type": "string",
          "description": "Title of the task."
        },
        "description": {
          "type": "string",
          "description": "Description of the task."
        },
        "status": {
          "type": "string",
          "description": "Status of the task (open, inProgress, done)."
        },
        "dueDate": {
          "type": "string",
          "description": "Due date of the task.",
          "format": "date-time"
        },
        "relatedLeadId": {
          "type": "string",
          "description": "Reference to Lead. (Relationship: Lead 1:N Task)"
        },
        "relatedOrderId": {
          "type": "string",
          "description": "Reference to ExportOrder. (Relationship: ExportOrder 1:N Task)"
        },
        "assigneeId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N Task)"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the task was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "title",
        "description",
        "status",
        "dueDate",
        "assigneeId",
        "createdAt"
      ]
    },
    "Document": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Document",
      "type": "object",
      "description": "Represents a document in the CRM system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Document entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the document."
        },
        "type": {
          "type": "string",
          "description": "Type of document (invoice, packingList, billOfLading, COO, certificate, other)."
        },
        "orderId": {
          "type": "string",
          "description": "Reference to ExportOrder. (Relationship: ExportOrder 1:N Document)"
        },
        "leadId": {
          "type": "string",
          "description": "Reference to Lead. (Relationship: Lead 1:N Document)"
        },
        "fileUrl": {
          "type": "string",
          "description": "URL of the document file.",
          "format": "uri"
        },
        "status": {
          "type": "string",
          "description": "Status of the document (pending, uploaded, verified)."
        },
        "expiryDate": {
          "type": "string",
          "description": "Expiry date of the document.",
          "format": "date-time"
        },
        "uploadedBy": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N Document) - The user who uploaded the document."
        },
        "uploadedAt": {
          "type": "string",
          "description": "Timestamp of when the document was uploaded.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "type",
        "fileUrl",
        "status",
        "uploadedBy",
        "uploadedAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product offered by the company.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the product."
        },
        "description": {
          "type": "string",
          "description": "Description of the product."
        },
        "hsCode": {
          "type": "string",
          "description": "Harmonized System code for the product."
        },
        "basePrice": {
          "type": "number",
          "description": "Base price per unit."
        },
        "imageUrl": {
          "type": "string",
          "description": "URL for the product image.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "name",
        "hsCode",
        "basePrice"
      ]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "Represents a note related to another entity.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Note entity."
        },
        "content": {
          "type": "string",
          "description": "The content of the note."
        },
        "relatedEntityType": {
          "type": "string",
          "description": "The type of entity this note is related to (e.g., 'Lead', 'Contact')."
        },
        "relatedEntityId": {
          "type": "string",
          "description": "The ID of the entity this note is related to."
        },
        "createdBy": {
          "type": "string",
          "description": "User ID of the note's creator."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the note was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "content",
        "relatedEntityType",
        "relatedEntityId",
        "createdBy",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles. Uses path-based ownership for security. The `userId` MUST MATCH `authUid`.",
          "params": [
            {
              "name": "userId",
              "description": "The Firebase Authentication UID of the user."
            }
          ]
        }
      },
      {
        "path": "/companies/{companyId}",
        "definition": {
          "entityName": "Company",
          "schema": {
            "$ref": "#/backend/entities/Company"
          },
          "description": "Stores company information. This is the root for all tenant data.",
          "params": [
            {
              "name": "companyId",
              "description": "Unique identifier for the company."
            }
          ]
        }
      },
      {
        "path": "/companies/{companyId}/contacts/{contactId}",
        "definition": {
          "entityName": "Contact",
          "schema": {
            "$ref": "#/backend/entities/Contact"
          },
          "description": "Stores contacts associated with a company.",
          "params": [
            {
              "name": "companyId",
              "description": "The ID of the company the contact belongs to."
            },
            {
              "name": "contactId",
              "description": "Unique identifier for the contact."
            }
          ]
        }
      },
      {
        "path": "/companies/{companyId}/leads/{leadId}",
        "definition": {
          "entityName": "Lead",
          "schema": {
            "$ref": "#/backend/entities/Lead"
          },
          "description": "Stores leads associated with a company. Includes denormalized `companyId` for authorization independence.",
          "params": [
            {
              "name": "companyId",
              "description": "The ID of the company the lead is associated with."
            },
            {
              "name": "leadId",
              "description": "Unique identifier for the lead."
            }
          ]
        }
      },
      {
        "path": "/companies/{companyId}/exportOrders/{exportOrderId}",
        "definition": {
          "entityName": "ExportOrder",
          "schema": {
            "$ref": "#/backend/entities/ExportOrder"
          },
          "description": "Stores export orders associated with a company. Includes denormalized `companyId` for authorization independence.",
          "params": [
            {
              "name": "companyId",
              "description": "The ID of the company the export order is associated with."
            },
            {
              "name": "exportOrderId",
              "description": "Unique identifier for the export order."
            }
          ]
        }
      },
      {
        "path": "/companies/{companyId}/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Stores products offered by a specific company.",
          "params": [
            {
              "name": "companyId",
              "description": "The ID of the company that owns this product."
            },
            {
              "name": "productId",
              "description": "Unique identifier for the product."
            }
          ]
        }
      },
      {
        "path": "/companies/{companyId}/notes/{noteId}",
        "definition": {
          "entityName": "Note",
          "schema": {
            "$ref": "#/backend/entities/Note"
          },
          "description": "Stores notes associated with various entities within a company.",
          "params": [
            {
              "name": "companyId",
              "description": "The ID of the company this note belongs to."
            },
            {
              "name": "noteId",
              "description": "Unique identifier for the note."
            }
          ]
        }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": {
            "$ref": "#/backend/entities/Task"
          },
          "description": "Stores tasks. These are top-level and secured by assigneeId.",
          "params": [
            {
              "name": "taskId",
              "description": "Unique identifier for the task."
            }
          ]
        }
      },
      {
        "path": "/documents/{documentId}",
        "definition": {
          "entityName": "Document",
          "schema": {
            "$ref": "#/backend/entities/Document"
          },
          "description": "Stores documents. These are top-level and secured by uploadedBy.",
          "params": [
            {
              "name": "documentId",
              "description": "Unique identifier for the document."
            }
          ]
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "role",
          "schema": {
            "type": "object",
            "properties": { "isAdmin": { "type": "boolean" } }
          },
          "description": "Stores admin roles. Existence of a document grants admin privileges.",
          "params": [
            {
              "name": "userId",
              "description": "The Firebase Authentication UID of the admin user."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed to enforce multi-tenancy. Most data is nested under a `/companies/{companyId}` collection. This ensures that all data is tied to a specific company tenant. A user's access to a company's data is determined by checking if the company's ID is present in the `companyIds` array on that user's profile document (`/users/{userId}`). This is a scalable and secure pattern for SaaS applications. Global data or user-specific data (like Tasks or user-uploaded Documents) can remain in top-level collections, secured by owner/assignee fields."
  }
}
