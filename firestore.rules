
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isAssignedTo(doc) {
      return doc.assignedUserId == request.auth.uid;
    }
     function isAssigneeOfTask(doc) {
      return doc.assigneeId == request.auth.uid;
    }


    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /usageStats/{docId} {
        allow read: if isAdmin();
        allow write: if false; // Only backend functions can write usage
    }

    match /leads/{leadId} {
      allow get: if isAdmin() || isAssignedTo(resource.data);
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isAssignedTo(resource.data);
      allow delete: if isAdmin();
    }

    match /exportOrders/{orderId} {
      allow get: if isAdmin() || isAssignedTo(resource.data);
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isAssignedTo(resource.data);
      allow delete: if isAdmin();

      match /lineItems/{itemId} {
        allow read, write: if get(/databases/$(database)/documents/exportOrders/$(orderId)).data.assignedUserId == request.auth.uid || isAdmin();
      }
      
      match /documentsChecklist/{docId} {
         allow read, write: if get(/databases/$(database)/documents/exportOrders/$(orderId)).data.assignedUserId == request.auth.uid || isAdmin();
      }
    }

    match /companies/{companyId} {
      allow read, write: if isSignedIn();
    }
    match /contacts/{contactId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow get, update, delete: if isAdmin() || isAssigneeOfTask(resource.data);
      allow list: if isSignedIn();
      allow create: if isSignedIn(); 
    }
    
    match /interactions/{interactionId} {
      function isAssignedToParent(docData) {
        let leadAccess = docData.leadId != null && isAssignedTo(get(/databases/$(database)/documents/leads/$(docData.leadId)).data);
        let orderAccess = docData.orderId != null && isAssignedTo(get(/databases/$(database)/documents/exportOrders/$(docData.orderId)).data);
        return leadAccess || orderAccess;
      }

      allow get: if isAdmin() || isAssignedToParent(resource.data);
      allow list: if isSignedIn();
      allow create: if isAdmin() || isAssignedToParent(request.resource.data);
      allow update, delete: if false;
    }

    match /documents/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /activityLogs/{logId} { // System-wide audit trail
      allow read: if isAdmin();
      allow create: if isSignedIn(); // Allow create for logging from client-side triggers (though should be backend)
      allow update, delete: if false;
    }
    match /activity_logs/{logId} { // User-facing feed
      allow read: if isSignedIn();
      allow write: if false; // Only backend triggers
    }
    match /whatsappEvents/{eventId} {
      allow read, write: if false; // Server-side debugging only
    }
     match /dashboardStats/{userId} {
        allow read: if isOwner(userId);
        allow write: if false;
    }
  }
}
