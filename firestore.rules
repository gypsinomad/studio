/**
 * # Firestore Security Rules for SpiceRoute CRM
 *
 * ## Core Philosophy
 * This ruleset enforces a multi-tenant, role-based security model. Data access is primarily controlled
 * by a user's membership in a company. A global "admin" role, determined by a specific email address,
 * provides system-wide administrative access. For standard users (salesExecutive), access to sensitive
 * documents is restricted to only those documents they are assigned to. The 'viewer' role has read-only access.
 *
 * ## Data Structure & Security Model
 * - **Admin Identification**: A user is considered an admin if their authenticated email matches a specific value.
 *   This check is performed by the `isAdmin()` function and bypasses most other role checks.
 * - `/users/{userId}`: Contains user profiles with a `companyIds` array and a `role` field.
 *   Non-admin roles (`salesExecutive`, `viewer`) are read from this document.
 * - `/companies/{companyId}`: The root for all tenant-specific data. Access requires company membership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A user is an admin if their verified email matches the hardcoded admin email.
     * This is the single source of truth for admin privileges.
     */
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified &&
             request.auth.token.email.toLowerCase() == 'akhilvenugopal@gmail.com';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserRole() {
        return getUserData().role;
    }
    
    function isSalesExecutive() {
        return isSignedIn() && getUserRole() == 'salesExecutive';
    }

    /**
     * Checks if the authenticated user is a member of the specified company.
     * It performs a single `get` on the user's own profile.
     */
    function isUserMemberOfCompany(companyId) {
      return isSignedIn() && companyId in getUserData().companyIds;
    }

    // =====================================================================
    // Global & Settings Collections
    // =====================================================================

    match /users/{userId} {
      // Users can read their own profile. Admins can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      // Admins can list all users for the user management screen.
      allow list: if isAdmin();
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      // Users can update their own profile, but cannot change their role. Admins can update anything.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    // Rule for dashboard stats. Users can read their own stats document.
    match /dashboardStats/{userId} {
      allow get: if isOwner(userId);
      allow list, create, update, delete: if false;
    }
    
    // AI settings can be read by any signed-in user, but only written by the admin.
    // The UI ensures only admins can see this data.
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }

    // AI usage stats can be read by any signed-in user, but only written by backend functions.
    // The UI ensures only admins can see this data.
    match /usageStats/{month} {
        allow get: if isSignedIn();
        allow write: if false; 
    }

    // WhatsApp webhook event logs are for debugging and created by a trusted server process.
    // No client access should be allowed.
    match /whatsappEvents/{eventId} {
      allow read, write: if false;
    }


    // =====================================================================
    // Company-level (Multi-Tenant) Collections
    // =====================================================================

    match /companies/{companyId} {
      // Allow access if user is a member of the company.
      allow get: if isUserMemberOfCompany(companyId);
      // Listing companies is not based on membership; queries should handle this.
      allow list: if isSignedIn(); 
      // Only admins can create/delete companies. Any member can update (e.g. company name).
      allow create: if isAdmin();
      allow update: if isUserMemberOfCompany(companyId);
      allow delete: if isAdmin();


      // === Generic read/write rule for simple collections ===
      match /contacts/{contactId} {
        allow read: if isUserMemberOfCompany(companyId);
        allow write: if isUserMemberOfCompany(companyId) && (isAdmin() || isSalesExecutive());
      }
      match /products/{productId} {
         allow read: if isUserMemberOfCompany(companyId);
         allow write: if isUserMemberOfCompany(companyId) && (isAdmin() || isSalesExecutive());
      }
       match /activity_logs/{logId} {
        allow get, list: if isUserMemberOfCompany(companyId);
        // Logs are created by functions, not clients.
        allow create, update, delete: if false;
      }
      match /notes/{noteId} {
         allow read: if isUserMemberOfCompany(companyId);
         allow write: if isUserMemberOfCompany(companyId) && (isAdmin() || isSalesExecutive());
      }


      // === Granular rules for assignment-based collections ===
      match /leads/{leadId} {
        // Read access for any company member.
        allow get, list: if isUserMemberOfCompany(companyId);
        // Write access for admins or sales executives who are assigned.
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || (isSalesExecutive() && request.resource.data.assignedUserId == request.auth.uid));
      }
       match /exportOrders/{orderId} {
        allow get, list: if isUserMemberOfCompany(companyId);
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || (isSalesExecutive() && request.resource.data.assignedUserId == request.auth.uid));

        // Rule for the lineItems subcollection
        match /lineItems/{lineItemId} {
           allow read: if isUserMemberOfCompany(companyId);
           allow write: if isUserMemberOfCompany(companyId) && (isAdmin() || (isSalesExecutive() && get(/databases/$(database)/documents/companies/$(companyId)/exportOrders/$(orderId)).data.assignedUserId == request.auth.uid));
        }
      }
       match /tasks/{taskId} {
        allow get, list: if isUserMemberOfCompany(companyId);
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || (isSalesExecutive() && request.resource.data.assigneeId == request.auth.uid));
      }
       match /documents/{documentId} {
        allow get, list: if isUserMemberOfCompany(companyId);
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || (isSalesExecutive() && request.resource.data.uploadedBy == request.auth.uid));
      }
    }
  }
}
