
rules_version = '2';

/**
 * @file firestore.rules
 * @description Firestore Security Rules for the SpiceRoute CRM application.
 *
 * @section Core Philosophy
 * This ruleset enforces a strict Role-Based Access Control (RBAC) model combined
 * with a user-ownership paradigm. There are two primary roles:
 * 1. Admin: Has full read/write access to most data for management and oversight.
 * 2. salesExecutive: Access is restricted to the documents they own or are explicitly
 *    assigned to, such as leads, tasks, and export orders.
 *
 * @section Data Structure
 * The data is organized into top-level collections for major entities (e.g.,
 * `/exportOrders`, `/companies`, `/tasks`). This flat structure promotes clear and efficient
 * security logic.
 *
 * @section Key Security Decisions
 * - Admin Access: Users are designated as admins if a document with their UID
 *   exists in the `/roles_admin` collection. Admins have broad read and write access
 *   to data across the database. This collection is intentionally made
 *   read-only via rules to prevent privilege escalation from the client-side.
 * - User Ownership: Data created by or assigned to a specific user (e.g., Leads,
 *   ExportOrders, Tasks) is secured using a denormalized ownership field
 *   (e.g., `assignedUserId`, `assigneeId`). This allows users to access only their
 *   own data, enforcing data isolation. Client queries MUST include a `where` clause
 *   to filter by this ownership field.
 * - User Profiles: User profiles at `/users/{userId}` can be read by any
 *   authenticated user to facilitate displaying user information, but can only be
 *   created or modified by the user themselves or an admin.
 * - Shared Data: Foundational collections like `/companies`, `/contacts`, and `/tags`
 *   are readable by any signed-in user but can only be created or modified by admins
 *   to maintain data integrity.
 * - Privacy: Listing the entire `/users` collection is explicitly forbidden for
 *   non-admins to protect user privacy.
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // `exists()` is more performant than `get()` for checking roles.
    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isExistingDoc() {
      return resource != null;
    }

    // Checks if the user is assigned to the document via `assignedUserId`.
    function isAssignedUser() {
      return resource.data.assignedUserId == request.auth.uid;
    }
    
    // Checks if the user is the assignee of a task via `assigneeId`.
    function isAssignee() {
        return resource.data.assigneeId == request.auth.uid;
    }

    // On create, ensures the new document's ownership field
    // is set to the creator's own UID.
    function isCreatingOwnContent(field) {
      return request.resource.data[field] == request.auth.uid;
    }
    
    // On update, ensures an ownership-related field cannot be changed.
    function isOwnershipFieldImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isSignedIn(); // Allow reading any user profile for display purposes.
      allow list: if isAdmin(); // Only admins can list all users.
      allow create: if isOwner(userId) && isCreatingOwnContent('authUid');
      allow update: if (isOwner(userId) || isAdmin()) && isOwnershipFieldImmutable('authUid');
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow get: if isSignedIn() && (isAssignedUser() || isAdmin());
      allow list: if isSignedIn(); // relies on client-side queries with where()
      allow create: if isSignedIn() && (isCreatingOwnContent('assignedUserId') || isAdmin());
      allow update: if isSignedIn() && (isAssignedUser() || isAdmin()) && isOwnershipFieldImmutable('assignedUserId');
      allow delete: if isSignedIn() && (isAssignedUser() || isAdmin());
    }

    match /exportOrders/{exportOrderId} {
      allow get: if isSignedIn() && (isAssignedUser() || isAdmin());
      allow list: if isSignedIn(); // relies on client-side queries with where()
      allow create: if isSignedIn() && (isCreatingOwnContent('assignedUserId') || isAdmin());
      allow update: if isSignedIn() && (isAssignedUser() || isAdmin()) && isOwnershipFieldImmutable('assignedUserId');
      allow delete: if isSignedIn() && (isAssignedUser() || isAdmin());
    }
    
    match /tasks/{taskId} {
      allow get: if isSignedIn() && (isAssignee() || isAdmin());
      allow list: if isSignedIn(); // relies on client-side queries with where()
      allow create: if isSignedIn() && (isCreatingOwnContent('assigneeId') || isAdmin());
      allow update: if isSignedIn() && (isAssignee() || isAdmin()) && isOwnershipFieldImmutable('assigneeId');
      allow delete: if isSignedIn() && (isAssignee() || isAdmin());
    }

    match /documents/{documentId} {
        allow get, update, delete: if isSignedIn() && (isOwner(resource.data.uploadedBy) || isAdmin());
        allow list: if isSignedIn(); // relies on client-side queries
        allow create: if isSignedIn() && isCreatingOwnContent('uploadedBy');
    }

    // Shared collections, readable by all, writable by admins.
    match /companies/{companyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    // Aggregated stats, only readable by the user they belong to. Writable by backend only.
    match /dashboardStats/{userId} {
        allow get: if isOwner(userId) || isAdmin();
        allow write: if false; // Only backend functions can write here.
    }
    
    // AI settings, readable by all authenticated users. Writable by admins (or backend).
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }
    
    // Usage stats, readable by admins. Writable by backend only.
    match /usageStats/{month} {
        allow get: if isAdmin();
        allow write: if false;
    }
  }
}
