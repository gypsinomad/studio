rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * EMERGENCY DEVELOPMENT RULES
     * Allows all users (even unauthenticated) to read and write all data.
     * Use this ONLY for debugging permission issues.
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
