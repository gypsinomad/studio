
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isAssignedTo(doc) {
      return doc.assignedUserId == request.auth.uid;
    }
     function isAssigneeOfTask(doc) {
      return doc.assigneeId == request.auth.uid;
    }


    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /usageStats/{docId} {
        allow read: if isAdmin();
        allow write: if false; // Only backend functions can write usage
    }

    match /leads/{leadId} {
      allow read: if isSignedIn(); // Allows list and get for all authenticated users
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isAssignedTo(resource.data));
      allow delete: if isAdmin();
    }

    match /exportOrders/{orderId} {
      allow read: if isSignedIn(); // Allows list and get for all authenticated users
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isAssignedTo(resource.data));
      allow delete: if isAdmin();

      match /lineItems/{itemId} {
        allow read, write: if isSignedIn(); // Simplify for now to prevent recursive get() issues
      }
      
      match /documentsChecklist/{docId} {
         allow read, write: if isSignedIn(); // Simplify for now
      }
    }

    match /companies/{companyId} {
      allow read, write: if isSignedIn();
    }
    match /contacts/{contactId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isAdmin() || isAssigneeOfTask(resource.data));
    }
    
    match /interactions/{interactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // RBAC check happens in the API route
      allow update, delete: if false;
    }

    match /documents/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /activityLogs/{logId} { // System-wide audit trail
      allow read: if isAdmin();
      allow create: if isSignedIn(); 
      allow update, delete: if false;
    }
    match /activity_logs/{logId} { // User-facing feed
      allow read: if isSignedIn();
      allow write: if false; // Only backend triggers
    }
    match /whatsappEvents/{eventId} {
      allow read, write: if false; // Server-side debugging only
    }
     match /dashboardStats/{userId} {
        allow read: if isOwner(userId);
        allow write: if false;
    }
  }
}
