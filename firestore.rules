
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to verify the user is signed in
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    /**
     * LEADS COLLECTION
     * Explicitly allowed for any authenticated user during development.
     */
    match /leads/{document=**} {
      allow read, write: if isSignedIn();
    }

    /**
     * USERS COLLECTION
     * Required for the useCurrentUser hook to load the user profile.
     */
    match /users/{document=**} {
      allow read, write: if isSignedIn();
    }

    /**
     * GLOBAL CATCH-ALL
     * Allows authenticated access to all other CRM collections (companies, orders, etc.)
     * Deployment Version: 1.0.6 - Forced deployment trigger
     */
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
