/**
 * # Firestore Security Rules for SpiceRoute CRM
 *
 * ## Core Philosophy
 * This ruleset enforces a multi-tenant security model where data access is primarily controlled by a user's membership in one or more companies. A global "admin" role exists to provide system-wide administrative access, bypassing standard tenancy checks. The default security posture is to deny access unless explicitly granted.
 *
 * ## Data Structure
 * - `/users/{userId}`: Contains user profiles, including a critical `companyIds` array that lists which companies the user belongs to. Access is restricted to the document owner.
 * - `/companies/{companyId}`: Acts as the root for all tenant-specific data.
 * - `/companies/{companyId}/{subcollection}`: Subcollections like `contacts`, `leads`, and `exportOrders` store data related to a specific company.
 * - `/tasks`, `/documents`: Top-level collections for items that may not be directly tied to a single company. Access is controlled by an `assigneeId` or `uploadedBy` field.
 * - `/roles_admin/{userId}`: A special collection used to grant global admin privileges. The existence of a document with the user's UID grants admin rights.
 *
 * ## Key Security Decisions
 * - **Multi-Tenancy via User Profile**: To determine if a user can access data within `/companies/{companyId}`, the rules perform a `get` operation on the user's own profile (`/users/{request.auth.uid}`) to check if their `companyIds` array contains the target `companyId`. This is a performant and secure pattern.
 * - **Admin Override**: A user is considered an admin if a document exists for them in the `/roles_admin` collection. Admins have read/write access to nearly all data across all companies.
 * - **Restricted Listing**: Listing documents in top-level collections like `/tasks` and `/documents` is restricted to admins to prevent data leakage. Non-admins can only `get` individual documents they are explicitly assigned to.
 * - **Client-Side Writes to Roles Denied**: The `/roles_admin` collection is read-only from the client to prevent privilege escalation. Admin roles must be managed server-side (e.g., via a Cloud Function).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated user is a member of the specified company.
     * It performs a single `get` on the user's own profile, which is efficient and secure.
     * The `companyIds` on the user profile is the source of truth for tenancy.
     */
    function isUserMemberOfCompany(companyId) {
      let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userProfile.data.companyIds.hasAny([companyId]);
    }
    
    function isAssignedToDoc(doc) {
      let docData = doc.data;
      return isSignedIn() && (
        ('assignedUserId' in docData && docData.assignedUserId == request.auth.uid) ||
        ('assigneeId' in docData && docData.assigneeId == request.auth.uid)
      );
    }
    
    function wasUploadedBy(doc) {
      return isSignedIn() && doc.data.uploadedBy == request.auth.uid;
    }
    
    // =====================================================================
    // Collection Rules
    // =====================================================================

    match /users/{userId} {
      // Users can read and update their own profile. Admins can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      // Admins can list all users for the user management screen.
      allow list: if isAdmin();
      // A user can create their own profile document.
      allow create: if isOwner(userId) && request.resource.data.authUid == userId;
      // Users can update their own profile, but cannot change their role. Admins can update anything.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      // Admins can see who else is an admin.
      allow get, list: if isAdmin();
      // Admin roles can only be granted from a backend process (e.g., Cloud Function).
      allow create, update, delete: if false;
    }

    // This is the root of our multi-tenant structure. All access to company data
    // and its subcollections must verify the user is a member of that company.
    match /companies/{companyId} {
      // Allow read/write access if user is a member of the company, or is an admin.
      allow get, list: if isUserMemberOfCompany(companyId) || isAdmin();
      allow create, update, delete: if isUserMemberOfCompany(companyId) || isAdmin();

      // Rules for all subcollections of a company.
      // This wildcard ensures the tenancy check is applied to leads, contacts, orders, etc.
      match /{subcollection}/{docId} {
         allow get, list, create, update, delete: if isUserMemberOfCompany(companyId) || isAdmin();
      }
    }

    match /tasks/{taskId} {
      allow get, create, update, delete: if isAssignedToDoc(resource) || isSignedIn();
      allow list: if isAdmin();
    }

    match /documents/{documentId} {
      allow get, create, update, delete: if wasUploadedBy(resource) || isAdmin();
      allow list: if isAdmin();
    }
  }
}
