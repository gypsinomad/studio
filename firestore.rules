rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * EMERGENCY DEVELOPMENT RULES - DEPLOYED: 2024-05-22T12:00:00Z
     * Allows all users (even unauthenticated) to read and write all data.
     * This removes all account restrictions and resolves permission issues for development.
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
