
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BLUEPRINT HELPERS ---
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }

    // --- BLUEPRINT: PER-USER DATA ---
    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    // --- MODULES ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /notifications/{notificationId} {
      // 1. Create: Any authenticated staff can send notifications to others (mentions, tasks)
      allow create: if isSignedIn();
      
      // 2. Read/Delete: Only the intended recipient or an admin can access/remove
      allow get, list, delete: if isOwner(resource.data) || isAdmin();
      
      // 3. Update: Read-receipts allowed, but ownership (userId) is strictly IMMUTABLE
      allow update: if (isOwner(resource.data) || isAdmin()) && 
                    request.resource.data.userId == resource.data.userId;
    }

    match /reminders/{reminderId} {
      // Personal reminders template
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isOwner(resource.data) || isAdmin();
      allow update: if (isOwner(resource.data) || isAdmin()) && 
                    request.resource.data.userId == resource.data.userId;
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants || resource.data.type == 'channel' || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    match /meetings/{meetingId} {
      allow read, write: if isSignedIn();
    }

    match /leads/{leadId} { allow read, write: if isSignedIn(); }
    match /exportOrders/{orderId} { allow read, write: if isSignedIn(); }
    match /activity_logs/{logId} { allow read, create: if isSignedIn(); }
    
    match /settings/{docId} { 
      // Visibility: Branding visible to all, Compliance only to Admin
      allow read: if isSignedIn() && (docId != 'organization' || isAdmin());
      allow write: if isAdmin(); 
    }
    
    match /usageStats/{docId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /documents/{docId} { allow read, create: if isSignedIn(); allow update, delete: if isSignedIn() && (isAdmin() || resource.data.status != 'finalized'); }
  }
}
