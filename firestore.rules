rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * CRITICAL RESET - DEPLOYED: 2024-05-23T10:00:00Z
     * This ruleset provides UNRESTRICTED ACCESS to all collections.
     * Use this for development to bypass permission denied errors.
     */
    match /{allPaths=**} {
      allow read, write: if true;
    }

    // Explicitly naming critical paths to ensure absolute clarity for the rule engine
    match /settings/{document=**} {
      allow read, write: if true;
    }
    
    match /leads/{document=**} {
      allow read, write: if true;
    }
    
    match /users/{document=**} {
      allow read, write: if true;
    }
  }
}
