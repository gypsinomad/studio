/**
 * # Firestore Security Rules for SpiceRoute CRM (Single-Tenant)
 *
 * ## Core Philosophy
 * This ruleset enforces a simple, role-based security model for a single internal team.
 * Any authenticated user can create, edit, and delete business data. A comprehensive
 * audit trail is kept in the `activityLogs` collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified &&
             request.auth.token.email.toLowerCase() == 'akhilvenugopal@gmail.com';
    }

    // =====================================================================
    // Global & Settings Collections
    // =====================================================================

    match /users {
      allow list: if isAdmin();
    }
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /dashboardStats/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }
    
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }

    match /usageStats/{month} {
        allow get: if isSignedIn();
        allow write: if false;
    }

    match /whatsappEvents/{eventId} {
      allow read, write: if false; // Server-side debugging only
    }
    
    match /activityLogs {
      allow list: if isSignedIn();
    }
    match /activityLogs/{logId} {
      allow get, create: if isSignedIn();
      allow update, delete: if false; // Logs are immutable
    }
    
    match /activity_logs {
        allow list: if isSignedIn();
    }
    match /activity_logs/{logId} {
      allow get: if isSignedIn();
      allow create, update, delete: if false; // Append-only from backend
    }

    // =====================================================================
    // Top-Level Business Data Collections
    // =====================================================================

    match /companies {
      allow list: if isSignedIn();
    }
    match /companies/{companyId} {
      allow get, create, update, delete: if isSignedIn();
    }

    match /contacts {
      allow list: if isSignedIn();
    }
    match /contacts/{contactId} {
       allow get, create, update, delete: if isSignedIn();
    }
    
    match /products {
       allow list: if isSignedIn();
    }
    match /products/{productId} {
       allow get, create, update: if isSignedIn();
       allow delete: if isAdmin();
    }
    
    match /notes {
       allow list: if isSignedIn();
    }
    match /notes/{noteId} {
       allow get, create, update, delete: if isSignedIn();
    }
    
    match /leads {
       allow list: if isSignedIn();
    }
    match /leads/{leadId} {
      allow get, create, update, delete: if isSignedIn();
    }
    
    match /exportOrders {
      allow list: if isSignedIn();
    }
    match /exportOrders/{orderId} {
      allow get, create, update, delete: if isSignedIn();

      match /lineItems {
        allow list: if isSignedIn();
      }
      match /lineItems/{lineItemId} {
         allow get, create, update, delete: if isSignedIn();
      }
    }
    
    match /tasks {
      allow list: if isSignedIn();
    }
    match /tasks/{taskId} {
      allow get, create, update, delete: if isSignedIn();
    }
    
    match /documents {
      allow list: if isSignedIn();
    }
    match /documents/{documentId} {
      allow get, create, update, delete: if isSignedIn();
    }
  }
}
