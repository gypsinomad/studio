rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // FORCE RESET: 2026-02-13T14:30:00Z
    // GLOBAL UNRESTRICTED ACCESS
    match /{allPaths=**} {
      allow read, write: if true;
    }
    
    // Explicit matches for collection-level operations (list/query)
    match /users/{userId} { allow read, write: if true; }
    match /leads/{leadId} { allow read, write: if true; }
    match /exportOrders/{orderId} { allow read, write: if true; }
    match /tasks/{taskId} { allow read, write: if true; }
    match /activity_logs/{logId} { allow read, write: if true; }
    match /activity_logs { allow read, write: if true; }
    match /settings/{docId} { allow read, write: if true; }
    match /interactions/{docId} { allow read, write: if true; }
    match /interactions { allow read, write: if true; }
    match /companies/{docId} { allow read, write: if true; }
    match /companies { allow read, write: if true; }
    match /contacts/{docId} { allow read, write: if true; }
    match /contacts { allow read, write: if true; }
    match /documents/{docId} { allow read, write: if true; }
    match /documents { allow read, write: if true; }
  }
}