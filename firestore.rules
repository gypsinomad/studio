/**
 * # Firestore Security Rules for SpiceRoute CRM
 *
 * ## Core Philosophy
 * This ruleset enforces a multi-tenant, role-based security model. Data access is primarily controlled
 * by a user's membership in a company. A global "admin" role provides system-wide administrative
 * access, bypassing standard tenancy checks for oversight. For standard users (salesExecutive),
 * access to sensitive documents like leads and orders is further restricted to only those documents
 * they are explicitly assigned to.
 *
 * ## Data Structure & Security Model
 * - `/users/{userId}`: Contains user profiles with a critical `companyIds` array and a `role`.
 *   Access is restricted to the document owner or an admin.
 * - `/companies/{companyId}`: The root for all tenant-specific data. Access requires membership.
 * - `/companies/{companyId}/leads/{leadId}` (and similar collections): Data for a specific company.
 *   - **Admin:** Can read/write all documents within any company they are a member of.
 *   - **salesExecutive:** Can only read/write documents where `assignedUserId == request.auth.uid`.
 *     They cannot list all documents; they must query for their own.
 *
 * ## Key Security Decisions
 * - **Multi-Tenancy via User Profile**: To check if a user can access `/companies/{companyId}`, the
 *   rules `get()` the user's own profile (`/users/{request.auth.uid}`) to see if their `companyIds`
 *   array contains the target `companyId`. This is a performant and secure pattern.
 * - **Admin Override**: The `isAdmin()` function checks the user's role on their profile. Admins
 *   can perform most actions within companies they belong to.
 * - **Ownership-Based Write Access**: For standard users, write access (`create`, `update`, `delete`)
 *   to leads, orders, and tasks requires the user's UID to match the `assignedUserId` on the document.
 * - **Restricted Listing**: `list` operations on sensitive subcollections (leads, orders, etc.)
 *   are restricted. Non-admins must construct client-side queries that filter by their own
 *   `assignedUserId`. The `get` rule then secures access to the individual documents returned by that query.
 *   This prevents a user from accidentally or maliciously listing all of a company's leads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    /**
     * Checks if the authenticated user is a member of the specified company.
     * It performs a single `get` on the user's own profile.
     */
    function isUserMemberOfCompany(companyId) {
      return isSignedIn() && companyId in getUserData().companyIds;
    }

    // =====================================================================
    // Collection Rules
    // =====================================================================

    match /users/{userId} {
      // Users can read and update their own profile. Admins can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      // Admins can list all users for the user management screen.
      allow list: if isAdmin();
      // A user can create their own profile document.
      allow create: if isOwner(userId);
      // Users can update their own profile, but cannot change their role. Admins can update anything.
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      // Only admins can delete users.
      allow delete: if isAdmin();
    }

    // This is the root of our multi-tenant structure.
    match /companies/{companyId} {
      // Allow access if user is a member of the company, or is an admin.
      allow get: if isUserMemberOfCompany(companyId) || isAdmin();
      // Listing companies is not based on membership; queries should handle this.
      allow list: if isSignedIn(); 
      // Only admins can create/delete companies, but any member can update (e.g. company name).
      allow create: if isAdmin();
      allow update, delete: if isUserMemberOfCompany(companyId) || isAdmin();

      // === Generic read-only rule for simple subcollections ===
      match /contacts/{contactId} {
        allow get, list: if isUserMemberOfCompany(companyId) || isAdmin();
        allow create, update, delete: if isUserMemberOfCompany(companyId) || isAdmin();
      }
      match /products/{productId} {
         allow get, list: if isUserMemberOfCompany(companyId) || isAdmin();
         allow create, update, delete: if isUserMemberOfCompany(companyId) || isAdmin();
      }
       match /activity_logs/{logId} {
        allow get, list: if isUserMemberOfCompany(companyId) || isAdmin();
        // Logs are created by functions, not clients.
        allow create, update, delete: if false;
      }
      match /notes/{noteId} {
         allow get, list, create, update, delete: if isUserMemberOfCompany(companyId) || isAdmin();
      }


      // === Granular rules for assignment-based collections ===
      match /leads/{leadId} {
        // Allow read if admin, or if user is assigned to the lead.
        allow get: if isUserMemberOfCompany(companyId) && (isAdmin() || resource.data.assignedUserId == request.auth.uid);
        // Only admins can list all leads in a company. Users query for their own.
        allow list: if isUserMemberOfCompany(companyId) && isAdmin();
        // Allow create/update/delete if admin, or if user is assigned.
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || request.resource.data.assignedUserId == request.auth.uid);
      }
       match /exportOrders/{orderId} {
        allow get: if isUserMemberOfCompany(companyId) && (isAdmin() || resource.data.assignedUserId == request.auth.uid);
        allow list: if isUserMemberOfCompany(companyId) && isAdmin();
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || request.resource.data.assignedUserId == request.auth.uid);
      }
       match /tasks/{taskId} {
        allow get: if isUserMemberOfCompany(companyId) && (isAdmin() || resource.data.assigneeId == request.auth.uid);
        allow list: if isUserMemberOfCompany(companyId) && isAdmin();
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || request.resource.data.assigneeId == request.auth.uid);
      }
       match /documents/{documentId} {
        allow get: if isUserMemberOfCompany(companyId) && (isAdmin() || resource.data.uploadedBy == request.auth.uid);
        allow list: if isUserMemberOfCompany(companyId) && isAdmin();
        allow create, update, delete: if isUserMemberOfCompany(companyId) && (isAdmin() || request.resource.data.uploadedBy == request.auth.uid);
      }
    }
  }
}
