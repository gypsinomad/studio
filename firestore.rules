/**
 * # Firestore Security Rules for SpiceRoute CRM (Single-Tenant)
 *
 * ## Core Philosophy
 * This ruleset enforces a simple, role-based security model for a single internal team.
 * Data access is primarily controlled by authentication state and a global admin role.
 * - **Admin Identification**: A user is an admin if their email matches a specific value.
 * - **Team Access**: All authenticated users are considered part of the team and can read/write operational data.
 * - **Destructive Actions**: Deleting primary records is restricted to the admin role to prevent accidental data loss.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A user is an admin if their verified email matches the hardcoded admin email.
     */
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified &&
             request.auth.token.email.toLowerCase() == 'akhilvenugopal@gmail.com';
    }

    // =====================================================================
    // Global & Settings Collections
    // =====================================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /dashboardStats/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // This data is written by a backend process, not the client.
      allow create, update, delete: if false;
    }
    
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }

    match /usageStats/{month} {
        allow get: if isSignedIn(); // Allow any team member to read for UI purposes
        allow write: if false; // Written by backend functions only
    }

    match /whatsappEvents/{eventId} {
      // For server-side debugging only. No client access.
      allow read, write: if false;
    }

    // =====================================================================
    // Top-Level Business Data Collections (Single-Tenant)
    // =====================================================================

    match /contacts/{contactId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /products/{productId} {
       allow read, list, create, update: if isSignedIn();
       allow delete: if isAdmin();
    }
    
     match /activity_logs/{logId} {
      allow get, list: if isSignedIn();
      // Logs are append-only from the backend.
      allow create, update, delete: if false;
    }
    
    match /notes/{noteId} {
       allow read, list, create, update: if isSignedIn();
       allow delete: if isAdmin();
    }
    
    match /leads/{leadId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    
     match /exportOrders/{orderId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isAdmin();

      match /lineItems/{lineItemId} {
         allow read, list, create, update, delete: if isSignedIn();
      }
    }
    
     match /tasks/{taskId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    
     match /documents/{documentId} {
      allow read, list, create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
  }
}
