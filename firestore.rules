rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified &&
             request.auth.token.email.toLowerCase() == 'akhilvenugopal@gmail.com';
    }

    // --- Default rule: Allow full access for any authenticated user ---
    // This is the baseline for the internal team tool.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
    
    // --- Overrides for specific collections that need tighter security ---

    // Users can only edit their own profile, and cannot change their role. Admins can manage all users.
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Users can view their own dashboard stats, but not change them directly.
    match /dashboardStats/{userId} {
      allow get, create: if isOwner(userId) || isAdmin();
      allow write: if false; // Should be updated by backend jobs, not the client.
    }
    
    // AI settings can be read by anyone, but only written by an admin.
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }

    // Usage stats are append-only from the backend.
    match /usageStats/{month} {
        allow get: if isSignedIn();
        allow write: if false;
    }

    // --- Log & Event Collections (stricter rules) ---

    // Raw webhook payloads are for server-side debugging only. No client access.
    match /whatsappEvents/{eventId} {
      allow read, write: if false;
    }
    
    // The main audit log is append-only for any authenticated user. No one can update or delete entries.
    match /activityLogs/{logId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }
    
    // The user-facing activity feed is written by the backend only.
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
