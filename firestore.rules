
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- User & Settings Collections (Most Specific Rules First) ---
    
    // Users can read all profiles, but can only update their own. Admins can update any.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId); // Allows new users to create their own profile
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // AI and other settings are readable by authenticated users, but only writable by admins.
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // AI usage stats are only readable by admins. Backend functions write to it.
    match /usageStats/{monthKey} {
      allow read: if isAdmin();
      allow write: if false; // Only backend can write.
    }

    // Dashboard stats are specific to each user.
    match /dashboardStats/{userId} {
      allow read, create: if isOwner(userId) || isAdmin();
      allow write: if false; // Should only be updated by backend jobs.
    }
    
    // --- Business Data Collections ---

    // Leads can be read/updated by their assignee or an admin.
    match /leads/{leadId} {
      allow read, update: if isSignedIn() && (isAdmin() || resource.data.assignedUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.assignedUserId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Export Orders can be read/updated by their assignee or an admin.
    match /exportOrders/{orderId} {
      allow read, update: if isSignedIn() && (isAdmin() || resource.data.assignedUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.assignedUserId == request.auth.uid;
      allow delete: if isAdmin();

      // Sub-collections must also be secured.
      match /lineItems/{lineItemId} {
         allow read, write: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/exportOrders/$(orderId)).data.assignedUserId == request.auth.uid);
      }
    }
    
    // All authenticated users can view companies. Only Admins can modify them.
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // All authenticated users can view and create contacts. Only Admins can modify them.
    match /contacts/{contactId} {
       allow read, create: if isSignedIn();
       allow update, delete: if isAdmin();
    }

    // Users can only manage tasks assigned to them. Admins can manage all tasks.
    match /tasks/{taskId} {
        allow read, write: if isSignedIn() && (isAdmin() || resource.data.assigneeId == request.auth.uid || request.resource.data.assigneeId == request.auth.uid);
    }
    
    // Documents can be read/written by any authenticated user for now.
    match /documents/{documentId} {
        allow read, write: if isSignedIn();
    }

    // --- Log & Event Collections (Append-Only or Read-Only) ---

    // The main audit log is append-only for any authenticated user.
    match /activityLogs/{logId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }
    
    // The user-facing activity feed is read-only for clients.
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if false; // Should be written by backend triggers/server-side logic
    }
    
    // Raw webhook payloads are for server-side debugging only. No client access.
    match /whatsappEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
