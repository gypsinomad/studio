rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.admin == true
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper for list queries: verifies that the query includes a filter for the current user's ID
    function isQueryByCurrentUser() {
      return request.query.filters.userId == request.auth.uid;
    }

    // Default catch-all: Authenticated staff can read/write everything not explicitly restricted below
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Notifications Rules: Optimized for query-based list permissions
    match /notifications/{notificationId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Split list rules ensure the query planner can verify safety without document-level lookups
      allow list: if isSignedIn() && isQueryByCurrentUser();
      allow list: if isAdmin();

      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) 
                    && request.resource.data.userId == resource.data.userId;
    }

    // Reminders Rules: Same pattern as notifications
    match /reminders/{reminderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow get, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow list: if isSignedIn() && isQueryByCurrentUser();
      allow list: if isAdmin();
    }
  }
}