rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified &&
             request.auth.token.email.toLowerCase() == 'akhilvenugopal@gmail.com';
    }

    // --- User & Settings Collections (Specific Rules) ---
    // These rules are matched first because they are more specific.

    // Users can only manage their own profile, and cannot change their role. Admins can manage all users.
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Users can view their own dashboard stats, but not change them directly.
    match /dashboardStats/{userId} {
      allow get, create: if isOwner(userId) || isAdmin();
      allow write: if false; // Should be updated by backend jobs, not the client.
    }
    
    // AI settings can be read by anyone, but only written by an admin.
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }

    // Usage stats are read-only for clients.
    match /usageStats/{month} {
        allow get: if isSignedIn();
        allow write: if false;
    }

    // --- Log & Event Collections (Specific Rules) ---

    // The main audit log is append-only for any authenticated user.
    match /activityLogs/{logId} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }
    
    // The user-facing activity feed is read-only for clients.
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    
    // Raw webhook payloads are for server-side debugging only. No client access.
    match /whatsappEvents/{eventId} {
      allow read, write: if false;
    }
    
    // --- Default Rule for All Other Data ---
    // This rule applies to any path not matched above (e.g., /leads, /tasks, /companies).
    // It grants full read/write access to any authenticated user.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
