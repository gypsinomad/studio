rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.admin == true
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default: Authenticated staff can read/write everything not explicitly restricted
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Strict Notifications Rules
    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow get, list, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) 
                    && request.resource.data.userId == resource.data.userId;
    }

    // Strict Reminders Rules
    match /reminders/{reminderId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}