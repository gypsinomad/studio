
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AUTHENTICATED ACCESS (DEVELOPMENT/DEBUG MODE)
     * This rule allows any user signed into the application via Firebase Auth
     * to read and write to any document in the database. 
     * This is intended to resolve persistent 'Missing or insufficient permissions' 
     * errors during the development of SpiceRoute CRM.
     */
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // You can re-introduce more granular role-based rules below as needed,
    // but the above catch-all will ensure the app remains functional.
  }
}
