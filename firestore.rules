/**
 * # Firestore Security Rules for SpiceRoute CRM (Single-Tenant)
 *
 * ## Core Philosophy
 * This ruleset enforces a simple, role-based security model for a single internal team.
 * All authenticated users can create, edit, and delete business data. A comprehensive
 * audit trail is kept in the `activityLogs` collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified &&
             request.auth.token.email.toLowerCase() == 'akhilvenugopal@gmail.com';
    }

    // =====================================================================
    // Global & Settings Collections
    // =====================================================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /dashboardStats/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }
    
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }

    match /usageStats/{month} {
        allow get: if isSignedIn();
        allow write: if false;
    }

    match /whatsappEvents/{eventId=**} {
      allow read, write: if false; // Server-side debugging only
    }
    
    // Audit Trail - append-only for all users
    match /activityLogs/{logId=**} {
      allow read, create: if isSignedIn();
      allow update, delete: if false;
    }
    
    // UI Activity Feed - backend writes, client reads
    match /activity_logs/{logId=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // =====================================================================
    // Top-Level Business Data Collections - All users can CRUD
    // =====================================================================

    match /companies/{companyId=**} {
      allow read, write: if isSignedIn();
    }

    match /contacts/{contactId=**} {
       allow read, write: if isSignedIn();
    }
    
    match /products/{productId=**} {
       allow read, write: if isSignedIn();
    }
    
    match /notes/{noteId=**} {
       allow read, write: if isSignedIn();
    }
    
    match /leads/{leadId=**} {
      allow read, write: if isSignedIn();
    }
    
    match /exportOrders/{orderId=**} {
      allow read, write: if isSignedIn();
    }
    
    match /tasks/{taskId=**} {
      allow read, write: if isSignedIn();
    }
    
    match /documents/{documentId=**} {
      allow read, write: if isSignedIn();
    }
  }
}
