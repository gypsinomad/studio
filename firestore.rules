rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * ULTRA-SIMPLE AUTHENTICATED ACCESS
     * This rule allows any authenticated user full read/write access to all collections.
     * This is intended to resolve persistent 'Missing or insufficient permissions' errors
     * by eliminating any potential rule evaluation complexity or document lookup failures.
     * 
     * Deployment Version: 1.0.8 - CRITICAL RESET
     */
    match /{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid != null;
    }
  }
}
