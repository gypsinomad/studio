
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // 1. Users: Manage own profile, Admin sees all
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Core CRM Collections: All authenticated users can Read/Write
    // This allows the app to function for all team members.
    
    match /leads/{docId} {
      allow read, write: if isSignedIn();
    }

    match /exportOrders/{docId} {
      allow read, write: if isSignedIn();
      
      // Allow access to all subcollections (lineItems, documentsChecklist, etc)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /companies/{docId} {
      allow read, write: if isSignedIn();
    }

    match /contacts/{docId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{docId} {
      allow read, write: if isSignedIn();
    }

    match /documents/{docId} {
      allow read, write: if isSignedIn();
    }

    match /interactions/{docId} {
      allow read, write: if isSignedIn();
    }

    match /activity_logs/{docId} {
      allow read, write: if isSignedIn();
    }

    match /activityLogs/{docId} {
      allow read, write: if isSignedIn();
    }

    match /whatsappEvents/{docId} {
      allow read, write: if isSignedIn();
    }
    
    match /products/{docId} {
      allow read, write: if isSignedIn();
    }
    
    match /notes/{docId} {
      allow read, write: if isSignedIn();
    }

    match /dashboardStats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; 
    }

    // 3. Restricted Admin Collections
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /usageStats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
