rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email_verified &&
             request.auth.token.email.toLowerCase() == 'akhilvenugopal@gmail.com';
    }

    // --- System & User Collections ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /dashboardStats/{userId} {
      allow get, create: if isOwner(userId) || isAdmin();
      allow update, delete: if false;
    }
    
    match /settings/ai {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }

    match /usageStats/{month} {
        allow get: if isSignedIn();
        allow write: if false;
    }

    // --- Log & Event Collections ---
    match /whatsappEvents/{eventId=**} {
      allow read, write: if false; // Server-side debugging only
    }
    
    match /activityLogs/{logId=**} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if false; // Append-only
    }
    
    match /activity_logs/{logId=**} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // Backend writes only
    }

    // --- Core Business Data Collections ---
    // Explicitly grant all CRUD permissions to any authenticated user.
    match /companies/{docId=**} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    match /contacts/{docId=**} {
       allow get, list, create, update, delete: if isSignedIn();
    }
    
    match /products/{docId=**} {
       allow get, list, create, update, delete: if isSignedIn();
    }
    
    match /notes/{docId=**} {
       allow get, list, create, update, delete: if isSignedIn();
    }
    
    match /leads/{docId=**} {
      allow get, list, create, update, delete: if isSignedIn();
    }
    
    match /exportOrders/{docId=**} {
      allow get, list, create, update, delete: if isSignedIn();
    }
    
    match /tasks/{docId=**} {
      allow get, list, create, update, delete: if isSignedIn();
    }
    
    match /documents/{docId=**} {
      allow get, list, create, update, delete: if isSignedIn();
    }
  }
}
