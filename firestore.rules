
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAssignedTo(docData) {
      return isSignedIn() && docData.assignedUserId == request.auth.uid;
    }

    function isAssigneeOfTask(docData) {
      return isSignedIn() && docData.assigneeId == request.auth.uid;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      // Allow any signed-in user to list and get leads.
      // Business logic in the app handles filtering for non-admins.
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isAssignedTo(resource.data));
      allow delete: if isAdmin();
    }

    match /exportOrders/{orderId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isAssignedTo(resource.data));
      allow delete: if isAdmin();

      match /lineItems/{itemId} {
        allow read, write: if isSignedIn();
      }
      
      match /documentsChecklist/{docId} {
         allow read, write: if isSignedIn();
      }
    }

    match /companies/{companyId} {
      allow read, write: if isSignedIn();
    }

    match /contacts/{contactId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || isAssigneeOfTask(resource.data));
    }
    
    match /interactions/{interactionId} {
      // Helper to check if the user has access to the parent entity of an interaction
      function canAccessParent(data) {
        return (data.leadId != null && exists(/databases/$(database)/documents/leads/$(data.leadId))) ||
               (data.orderId != null && exists(/databases/$(database)/documents/exportOrders/$(data.orderId)));
      }

      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /documents/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /usageStats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /dashboardStats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }
  }
}
